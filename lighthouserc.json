{
  "ci": {
    "collect": {
      "url": [
        "https://cubxxw.com/",
        "https://cubxxw.com/zh/",
        "https://cubxxw.com/about/",
        "https://cubxxw.com/zh/about/",
        "https://cubxxw.com/ai-technology/",
        "https://cubxxw.com/zh/ai-technology/",
        "https://cubxxw.com/growth/",
        "https://cubxxw.com/zh/growth/",
        "https://cubxxw.com/projects/",
        "https://cubxxw.com/archives/",
        "https://cubxxw.com/ai-technology/posts/agent-identity-from-locke-to-openclaw/",
        "https://cubxxw.com/zh/growth/posts/2025-annual-review/"
      ],
      "numberOfRuns": 1,
      "settings": {
        "chromeFlags": "--no-sandbox --disable-dev-shm-usage"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance":    ["warn",  { "minScore": 0.80 }],
        "categories:accessibility":  ["warn",  { "minScore": 0.85 }],
        "categories:best-practices": ["error", { "minScore": 0.90 }],
        "categories:seo":            ["error", { "minScore": 0.90 }],
        "meta-description":          ["error", {}],
        "document-title":            ["error", {}],
        "html-has-lang":             ["error", {}],
        "canonical":                 ["warn",  {}],
        "robots-txt":                ["warn",  {}],
        "hreflang":                  ["warn",  {}]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci",
      "reportFilenamePattern": "%%HOSTNAME%%-%%PATHNAME%%-%%DATETIME%%.%%EXTENSION%%"
    }
  }
}

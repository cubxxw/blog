# =============================================================================
# Copy to .env and fill in real values. Never commit .env.
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# LLM — DashScope (阿里云百炼)
# Console: https://bailian.console.aliyun.com/
# -----------------------------------------------------------------------------
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-turbo

# -----------------------------------------------------------------------------
# Image / Video Generation — Volcengine Ark (火山方舟)
# Console: https://console.volcengine.com/ark/
# -----------------------------------------------------------------------------
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_PROJECT_NAME=default
ARK_API_KEY_NAME=image-video-generation

# -----------------------------------------------------------------------------
# SEO — Baidu 普通收录 API
# Token: https://ziyuan.baidu.com/linksubmit/  ("修改准入密钥" to rotate)
# -----------------------------------------------------------------------------
BAIDU_PUSH_TOKEN=
BAIDU_PUSH_SITE=https://cubxxw.com

# -----------------------------------------------------------------------------
# SEO — IndexNow (Bing + Yandex, one push covers both)
# INDEXNOW_KEY must be a 32-char hex UUID (no dashes).
# A file named <INDEXNOW_KEY>.txt containing the key must be served at
# INDEXNOW_KEY_LOCATION — place it in static/ so it deploys to site root.
# -----------------------------------------------------------------------------
INDEXNOW_KEY=
INDEXNOW_KEY_LOCATION=https://cubxxw.com/<INDEXNOW_KEY>.txt

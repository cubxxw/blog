  "naming_conventions": {
    "format": "Title Case (首字母大写)",
    "examples": ["Personal Growth", "Cloud Native", "Open Source"],
    "chinese_format": "中文 + (英文)",
    "chinese_examples": ["部署 (Deployment)", "微服务 (Microservices)"],
    "rules": [
      "1. 优先使用英文术语",
      "2. 中文术语需附带英文翻译",
      "3. 避免纯中文 tag（不利于国际化）",
      "4. 避免过长描述性文字作为 tag",
      "5. 每个 tag 应该是一个独立的概念",
      "6. 避免 tag 嵌套（如 'blog - Annual Recap'）"
    ]
  }

{
  "name": "cubxxw-blog",
  "version": "1.0.0",
  "private": true,
  "description": "Blog E2E tests with Playwright",
  "scripts": {
    "dev:stop": "bash scripts/stop-netlify-dev.sh",
    "tags:check": "node scripts/normalize-tags.mjs --check",
    "tags:fix": "node scripts/normalize-tags.mjs --write",
    "flavor:check": "node scripts/check-ai-flavor.mjs --changed --check",
    "flavor:scan": "node scripts/check-ai-flavor.mjs",
    "geo:audit": "node scripts/geo-audit.mjs",
    "covers": "node --env-file-if-exists=.env scripts/generate-covers.mjs",
    "covers:write": "node --env-file-if-exists=.env scripts/generate-covers.mjs --write",
    "covers:test": "node --test scripts/generate-covers.test.mjs",
    "mcp:server": "node scripts/mcp-server.mjs",
    "baidu:push": "node scripts/baidu-push.mjs",
    "baidu:push:all": "node scripts/baidu-push.mjs --all",
    "baidu:push:dry": "node scripts/baidu-push.mjs --dry-run",
    "indexnow:push": "node scripts/indexnow-push.mjs",
    "indexnow:push:all": "node scripts/indexnow-push.mjs --all",
    "indexnow:push:dry": "node scripts/indexnow-push.mjs --dry-run",
    "seo:gsc": "node scripts/gsc-fetch.mjs",
    "seo:gsc:dry": "node scripts/gsc-fetch.mjs --dry-run",
    "seo:psi": "node scripts/psi-fetch.mjs",
    "seo:psi:dry": "node scripts/psi-fetch.mjs --dry-run",
    "seo:crux": "node scripts/crux-fetch.mjs",
    "seo:crux:dry": "node scripts/crux-fetch.mjs --dry-run",
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report"
  },
  "devDependencies": {
    "@netlify/functions": "^5.3.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^25.6.0",
    "netlify-plugin-critical-css": "^1.0.4",
    "typescript": "^5.4.5"
  }
}

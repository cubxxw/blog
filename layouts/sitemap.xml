{{- "<?xml version=\"1.0\" encoding=\"UTF-8\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1">
  {{- $excludedLayouts := slice "search" "archives" "categories" }}
  {{- range .Site.Pages -}}
    {{- $page := . -}}
    {{- $skip := false -}}
    {{- if .Params.private }}{{ $skip = true }}{{ end -}}
    {{- if partial "seo/should-noindex.html" . }}{{ $skip = true }}{{ end -}}
    {{- if eq .Params.sitemap_exclude true }}{{ $skip = true }}{{ end -}}
    {{- if in $excludedLayouts .Layout }}{{ $skip = true }}{{ end -}}
    {{- if or (eq .Kind "404") (strings.Contains .RelPermalink "/404") }}{{ $skip = true }}{{ end -}}
    {{- if not (in (slice "page" "home" "section" "taxonomy" "term") .Kind) }}{{ $skip = true }}{{ end -}}
    {{- if not $skip -}}
  <url>
    <loc>{{ .Permalink }}</loc>
    {{- if not .Lastmod.IsZero }}
    <lastmod>{{ .Lastmod.Format "2006-01-02T15:04:05+08:00" }}</lastmod>
    {{- else if not .Date.IsZero }}
    <lastmod>{{ .Date.Format "2006-01-02T15:04:05+08:00" }}</lastmod>
    {{- end }}
    {{- if .Params.changefreq }}
    <changefreq>{{ .Params.changefreq }}</changefreq>
    {{- else if eq .Kind "home" }}
    <changefreq>daily</changefreq>
    {{- else if eq .Kind "section" }}
    <changefreq>weekly</changefreq>
    {{- else }}
    <changefreq>monthly</changefreq>
    {{- end }}
    {{- if .Params.sitemapPriority }}
    <priority>{{ .Params.sitemapPriority }}</priority>
    {{- else if eq .Kind "home" }}
    <priority>1.0</priority>
    {{- else if eq .Kind "section" }}
    <priority>0.8</priority>
    {{- else if eq .Kind "taxonomy" }}
    <priority>0.6</priority>
    {{- else if eq .Kind "term" }}
    <priority>0.5</priority>
    {{- else }}
    <priority>0.7</priority>
    {{- end }}
    {{- with .Params.cover.image -}}
    {{- $imgURL := "" -}}
    {{- if or (hasPrefix . "http://") (hasPrefix . "https://") -}}
      {{- $imgURL = . -}}
    {{- else if hasPrefix . "/" -}}
      {{- $imgURL = . | absURL -}}
    {{- else -}}
      {{- with $page.Resources.GetMatch . -}}
        {{- $imgURL = .Permalink -}}
      {{- else -}}
        {{- with resources.GetMatch . -}}
          {{- $imgURL = .Permalink -}}
        {{- else -}}
          {{- $imgURL = . | absURL -}}
        {{- end -}}
      {{- end -}}
    {{- end -}}
    {{- if $imgURL }}
    <image:image>
      <image:loc>{{ $imgURL }}</image:loc>
      <image:title>{{ $page.Title }}</image:title>
      {{- with $page.Params.cover.alt }}
      <image:caption>{{ . | plainify }}</image:caption>
      {{- end }}
    </image:image>
    {{- end -}}
    {{- end -}}
    {{- /* hreflang annotations (mirror layouts/partials/head.html). Emit
           one xhtml:link per translation of this page — Hugo's
           AllTranslations includes the current page since v0.62, so
           single-language pages get one self-referencing alternate,
           which is the shape Google recommends. Then add x-default
           pointing at the default-language version (.Sites is ordered
           by language weight, so the first entry is the default). */ -}}
    {{- $defaultLang := (index .Sites 0).Language.Lang -}}
    {{- $defaultURL := .Permalink -}}
    {{- range .AllTranslations }}
    <xhtml:link rel="alternate" hreflang="{{ .Language.Lang }}" href="{{ .Permalink }}"/>
    {{- if eq .Language.Lang $defaultLang -}}{{- $defaultURL = .Permalink -}}{{- end -}}
    {{- end }}
    <xhtml:link rel="alternate" hreflang="x-default" href="{{ $defaultURL }}"/>
  </url>
    {{- end -}}
  {{- end }}
</urlset>
